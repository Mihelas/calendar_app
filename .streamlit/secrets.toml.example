# Copy this file to `secrets.toml` and fill in real values.
# Never commit the real secrets.toml to git.

# Public URL where the app is reachable. Must exactly match the
# "Authorized redirect URI" you configured in the Google Cloud OAuth client.
# Examples:
#   - Local dev:           "http://localhost:8501"
#   - Streamlit Cloud:     "https://your-app-name.streamlit.app"
redirect_uri = "http://localhost:8501"

# Only these Google account emails are allowed to use the app.
# Leave empty list [] to allow anyone who can complete OAuth (not recommended).
allowed_emails = [
    "user1@example.com",
    "user2@example.com",
]

# Google OAuth 2.0 Web client credentials.
# Create at: https://console.cloud.google.com/apis/credentials
[google_oauth]
client_id = "YOUR_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET"

# Gemini API key for parsing pasted emails into structured appointment data.
# Free tier is sufficient for low volume. Get one at:
#   https://aistudio.google.com/apikey
gemini_api_key = "YOUR_GEMINI_API_KEY"
